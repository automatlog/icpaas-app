# icpaas mobile — runtime env. Leave empty: API keys are entered via the
# in-app Config screen (AsyncStorage). No database URL is required.

# Optional dev-only fallback bearer. Set this in your local `.env` to
# avoid signing in every reload. NEVER commit a live token here. In
# production builds (EAS) leave it unset so users must sign in.
# EXPO_PUBLIC_DEFAULT_TOKEN=
